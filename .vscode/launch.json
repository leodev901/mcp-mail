{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MAIL MCP",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "module": "uvicorn",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      // "debugAdapterPython": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": [
        "app.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8003"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "internalConsole",
      "jinja": true
    },
    {
      "name": "MCP-CMN Server",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "module": "uvicorn",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      // "debugAdapterPython": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": [
        "cmn.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8004"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/.venv/Scripts/python.exe"
      },
      "console": "internalConsole",
      "jinja": true
    }
  ],
  "compounds": [
    {
      "name": "Compound",
      "configurations": ["MAIL MCP","MCP-CMN Server"]
    }
  ]
  
}